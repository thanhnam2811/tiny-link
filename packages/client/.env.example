# NextAuth (Auth.js) Configuration
# Run 'npx auth secret' to generate a secure AUTH_SECRET
AUTH_SECRET=__CHANGE_ME__
AUTH_URL=http://localhost:3000

# OAuth Providers
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Database (Prisma Adapter)
DATABASE_URL="postgresql://user:password@host:port/dbname?schema=public&sslmode=require"

# Backend Integration
# NEXT_PUBLIC_API_URL: Public endpoint for the Next.js BFF proxy (MUST include /api)
NEXT_PUBLIC_API_URL=http://localhost:3000/api
# INTERNAL_API_URL: Private base URL for the Fastify server (do NOT include /api)
INTERNAL_API_URL=http://localhost:3001
INTERNAL_API_KEY=__CHANGE_ME__
