{
	"name": "tiny-link",
	"private": true,
	"version": "1.0.0",
	"packageManager": "pnpm@10.32.1",
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"clean": "rimraf --glob \"packages/*/{dist,*.tsbuildinfo}\"",
		"clean:all": "rimraf --glob \"packages/*/{dist,node_modules,*.tsbuildinfo}\" node_modules pnpm-lock.yaml",
		"prebuild": "pnpm run clean && pnpm --filter @tiny-link/shared run build",
		"build": "pnpm --recursive run build",
		"start:server": "pnpm --filter @tiny-link/server start",
		"lint": "eslint .",
		"format": "prettier --write .",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{js,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{json,md}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@eslint/js": "^10.0.1",
		"@types/node": "^25.4.0",
		"eslint": "^10.0.3",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.3",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0"
	}
}
