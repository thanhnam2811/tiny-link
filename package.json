{
	"name": "tiny-link",
	"private": true,
	"version": "1.5.7",
	"packageManager": "pnpm@10.32.1",
	"type": "module",
	"workspaces": [
		"packages/*"
	],
	"scripts": {
		"dev": "pnpm --parallel --recursive run dev",
		"build": "pnpm run clean && pnpm --filter @tiny-link/shared run build && pnpm --recursive run build",
		"start": "pnpm --filter @tiny-link/server start",
		"docker:up": "docker compose up -d postgres redis",
		"docker:down": "docker compose down",
		"docker:build": "docker compose build",
		"docker:run": "docker compose run --rm",
		"clean": "rimraf --glob \"packages/*/{dist,*.tsbuildinfo}\"",
		"lint": "pnpm --recursive run lint",
		"test": "pnpm --recursive run test",
		"format": "prettier --write .",
		"prepare": "husky"
	},
	"lint-staged": {
		"packages/server/**/*.{js,ts}": [
			"pnpm --filter @tiny-link/server exec eslint --fix"
		],
		"packages/client/**/*.{js,jsx,ts,tsx}": [
			"pnpm --filter @tiny-link/client exec eslint --fix"
		],
		"*.{js,jsx,ts,tsx,json,md}": [
			"prettier --write"
		]
	},
	"devDependencies": {
		"@commitlint/cli": "^20.4.3",
		"@commitlint/config-conventional": "^20.4.3",
		"@eslint/js": "^9.21.0",
		"@types/node": "^25.4.0",
		"cross-env": "^10.1.0",
		"eslint": "^9.21.0",
		"globals": "^17.4.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.3",
		"prettier": "^3.8.1",
		"rimraf": "^6.1.3",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.57.0"
	}
}
